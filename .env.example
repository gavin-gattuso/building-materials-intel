# Required for Supabase scripts (push-to-supabase.ts, sync-local-to-supabase.ts)
SUPABASE_ACCESS_TOKEN=sbp_your_access_token_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Required for Vercel-deployed API (api/index.ts)
SUPABASE_URL=https://pmjqymxdaiwfpfglwqux.supabase.co

# Optional - enables AI chat mode on the website (omit for smart search mode)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Required for email briefing (api/send-briefing.ts)
RESEND_API_KEY=re_your_resend_api_key
BRIEFING_API_KEY=your_secret_key_here

# S&P Capital IQ API (primary financial data source; falls back to Yahoo Finance)
CAPIQ_API_KEY=
CAPIQ_API_SECRET=
CAPIQ_BASE_URL=
CAPIQ_RATE_LIMIT_PER_MINUTE=60

# FX rate APIs (free, no keys required)
ECB_API_BASE_URL=https://data-api.ecb.europa.eu
BOE_API_BASE_URL=https://www.bankofengland.co.uk/boeapps/database

# Prompt & model version tracking (see config/prompt-versions.json for registry)
PROMPT_VERSION_EXTRACTION=extraction-v1.0
PROMPT_VERSION_SUMMARY_STANDARD=summary-standard-v1.0
PROMPT_VERSION_SUMMARY_EARNINGS=summary-earnings-v1.0
PROMPT_VERSION_SECTION_TAGGING=tagging-v1.0

MODEL_EXTRACTION=claude-haiku-4-5-20251001
MODEL_SUMMARY_STANDARD=claude-haiku-4-5-20251001
MODEL_SUMMARY_EARNINGS=claude-sonnet-4-6
MODEL_REPORT_GENERATION=claude-sonnet-4-6
