{
  "buildCommand": "npm install && npx bun site/build-static.ts",
  "outputDirectory": "site/public",
  "crons": [
    { "path": "/api/daily-scan?key=cron", "schedule": "0 4 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://api.resend.com" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/build-report", "destination": "/api/build-report" },
    { "source": "/api/send-briefing", "destination": "/api/send-briefing" },
    { "source": "/api/db", "destination": "/api/db" },
    { "source": "/api/daily-scan", "destination": "/api/daily-scan" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
