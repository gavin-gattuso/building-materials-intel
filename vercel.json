{
  "buildCommand": "npm install",
  "outputDirectory": "site/public",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3",
      "includeFiles": "knowledge-base/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
