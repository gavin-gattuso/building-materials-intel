{
  "buildCommand": "npm install && npx bun site/build-static.ts",
  "outputDirectory": "site/public",
  "rewrites": [
    { "source": "/api/build-report", "destination": "/api/build-report" },
    { "source": "/api/send-briefing", "destination": "/api/send-briefing" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
